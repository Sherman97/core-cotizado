  "item": [
    {
      "name": "1. Crear folio",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/folios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "folios"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "var folio = json.data.numeroFolio;",
              "pm.collectionVariables.set('folio', folio);",
              "pm.test('folio generado', function () {",
              "  pm.expect(folio).to.be.a('string').and.not.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
